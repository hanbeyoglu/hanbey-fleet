generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  OWNER
  MANAGER
  ACCOUNTANT
  DRIVER
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
}

enum VehicleStatus {
  IDLE
  ACTIVE_SHIFT
  MAINTENANCE
  OUT_OF_SERVICE
}

enum ShiftStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ShiftType {
  DAY
  NIGHT
}

enum ExpenseCategory {
  FUEL
  MAINTENANCE
  INSURANCE
  TAX
  PENALTY
  CLEANING
  PARKING
  OTHER
}

enum DriverReportSource {
  MANUAL
  WHATSAPP
  MOBILE
  OCR
}

enum SettlementStatus {
  MATCHED
  MISMATCH
  APPROVED
}

enum ImportSource {
  MANUAL
  WHATSAPP
  OCR
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum OwnerType {
  VEHICLE
  DRIVER
}

enum DocumentType {
  VEHICLE_LICENSE
  REGISTRATION
  INSURANCE
  COMPREHENSIVE_INSURANCE
  INSPECTION
  EXHAUST_EMISSION
  MUNICIPALITY_PERMIT
  TAXI_PLATE_PERMIT
  DRIVER_LICENSE
  SRC_CERTIFICATE
  PSYCHOTECHNIC_CERTIFICATE
  CRIMINAL_RECORD
  ID_CARD
  CONTRACT
}

// ─────────────────────────────────────────────
// Fleet Owner domain
// ─────────────────────────────────────────────

model FleetOwner {
  id          String    @id @default(uuid())
  name        String
  phone       String    @unique
  email       String?
  address     String?
  taxNumber   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  memberships FleetMembership[]
  vehicles    Vehicle[]

  @@index([phone])
  @@map("fleet_owners")
}

model FleetMembership {
  id           String           @id @default(uuid())
  fleetOwnerId String
  userId       String
  role         Role
  status       MembershipStatus @default(ACTIVE)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  fleetOwner FleetOwner @relation(fields: [fleetOwnerId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@unique([fleetOwnerId, userId])
  @@index([fleetOwnerId])
  @@index([userId])
  @@index([status])
  @@map("fleet_memberships")
}

// ─────────────────────────────────────────────
// Core identity and authentication
// ─────────────────────────────────────────────

model User {
  id        String    @id @default(uuid())
  username  String    @unique
  email     String?   @unique
  phone     String?   @unique
  password  String
  name      String
  role      Role      @default(DRIVER)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  driver               Driver?
  notifications        Notification[]
  approvedDriverReports DriverReport[] @relation("ApprovedDriverReports")
  approvedSettlements  Settlement[]   @relation("ApprovedSettlements")
  assignmentsMade      VehicleAssignment[] @relation("AssignmentsMade")
  fleetMemberships     FleetMembership[]

  @@index([phone])
  @@map("users")
}

// ─────────────────────────────────────────────
// Fleet Management domain
// ─────────────────────────────────────────────

model Vehicle {
  id             String        @id @default(uuid())
  plate          String        @unique
  brand          String
  model          String
  year           Int
  color          String?
  status         VehicleStatus @default(IDLE)
  currentMileage Int           @default(0)
  dailyFee       Decimal       @default(0) @db.Decimal(12, 2)
  hgsTag         String?
  notes          String?
  fleetOwnerId   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  fleetOwner         FleetOwner?         @relation(fields: [fleetOwnerId], references: [id])
  shifts             Shift[]
  expenses           Expense[]
  maintenanceRecords MaintenanceRecord[]
  hgsTransits        HgsTransit[]
  timelineEvents     TimelineEvent[]
  assignments        VehicleAssignment[]

  @@index([status])
  @@index([fleetOwnerId])
  @@index([createdAt])
  @@map("vehicles")
}

// ─────────────────────────────────────────────
// Driver Management domain
// ─────────────────────────────────────────────

model Driver {
  id        String    @id @default(uuid())
  userId    String    @unique
  licenseNo String    @unique
  phone     String
  address   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user        User                @relation(fields: [userId], references: [id])
  shifts      Shift[]
  assignments VehicleAssignment[]

  @@map("drivers")
}

// VehicleAssignment is an independent aggregate separate from Shift.
// A driver may be assigned to a vehicle for days while multiple shifts occur.
// Status (ACTIVE/RELEASED) is computed from releasedAt: null=ACTIVE, set=RELEASED.
// BR-124: Assignments are never deleted. Only released.
// BR-120/BR-121: Only one active assignment per vehicle and per driver (enforced at service layer).
model VehicleAssignment {
  id            String    @id @default(uuid())
  vehicleId     String
  driverId      String
  assignedById  String
  assignedAt    DateTime  @default(now())
  releasedAt    DateTime?
  releaseReason String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  vehicle    Vehicle @relation(fields: [vehicleId], references: [id])
  driver     Driver  @relation(fields: [driverId], references: [id])
  assignedBy User    @relation("AssignmentsMade", fields: [assignedById], references: [id])

  @@index([vehicleId])
  @@index([driverId])
  @@index([assignedById])
  @@index([releasedAt])
  @@map("vehicle_assignments")
}

// ─────────────────────────────────────────────
// Operations domain
// ─────────────────────────────────────────────

model Shift {
  id           String      @id @default(uuid())
  vehicleId    String
  driverId     String
  plannedStart DateTime
  plannedEnd   DateTime
  actualStart  DateTime?
  actualEnd    DateTime?
  status         ShiftStatus @default(PLANNED)
  type           ShiftType?
  openingMileage Int
  closingMileage Int?
  cancelReason   String?
  notes          String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  vehicle        Vehicle        @relation(fields: [vehicleId], references: [id])
  driver         Driver         @relation(fields: [driverId], references: [id])
  driverReport   DriverReport?
  settlement     Settlement?
  hgsTransits    HgsTransit[]
  expenses       Expense[]
  timelineEvents TimelineEvent[]

  @@index([vehicleId])
  @@index([driverId])
  @@index([status])
  @@map("shifts")
}

model DriverReport {
  id              String             @id @default(uuid())
  shiftId         String             @unique
  source          DriverReportSource @default(MANUAL)
  rawMessage      String?
  declaredRevenue Decimal            @db.Decimal(12, 2)
  declaredHgs     Decimal            @db.Decimal(10, 2)
  declaredTotal   Decimal            @db.Decimal(12, 2)
  notes           String?
  isApproved      Boolean            @default(false)
  approvedById    String?
  approvedAt      DateTime?
  cashRevenue     Decimal?           @db.Decimal(12, 2)
  cardRevenue     Decimal?           @db.Decimal(12, 2)
  posRevenue      Decimal?           @db.Decimal(12, 2)
  tips            Decimal?           @db.Decimal(12, 2)
  cashDelivered   Decimal?           @db.Decimal(12, 2)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  shift      Shift       @relation(fields: [shiftId], references: [id])
  approvedBy User?       @relation("ApprovedDriverReports", fields: [approvedById], references: [id])
  settlement Settlement?
  importJob  ImportJob?

  @@index([isApproved])
  @@map("driver_reports")
}

// ─────────────────────────────────────────────
// Financial domain
// ─────────────────────────────────────────────

model Expense {
  id          String          @id @default(uuid())
  vehicleId   String
  shiftId     String?
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(12, 2)
  note        String?
  expenseDate DateTime
  receiptUrl  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  vehicle           Vehicle            @relation(fields: [vehicleId], references: [id])
  shift             Shift?             @relation(fields: [shiftId], references: [id])
  maintenanceRecord MaintenanceRecord?

  @@index([vehicleId])
  @@index([shiftId])
  @@index([category])
  @@index([expenseDate])
  @@map("expenses")
}

model Settlement {
  id              String           @id @default(uuid())
  shiftId         String           @unique
  driverReportId  String           @unique
  declaredRevenue Decimal          @db.Decimal(12, 2)
  declaredHgs     Decimal          @db.Decimal(10, 2)
  actualHgs       Decimal          @db.Decimal(10, 2)
  expenses        Decimal          @db.Decimal(12, 2)
  difference      Decimal          @db.Decimal(10, 2)
  netRevenue      Decimal          @db.Decimal(12, 2)
  status          SettlementStatus
  approvedById    String?
  approvedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  shift        Shift        @relation(fields: [shiftId], references: [id])
  driverReport DriverReport @relation(fields: [driverReportId], references: [id])
  approvedBy   User?        @relation("ApprovedSettlements", fields: [approvedById], references: [id])

  @@index([status])
  @@index([createdAt])
  @@map("settlements")
}

// ─────────────────────────────────────────────
// Maintenance domain
// ─────────────────────────────────────────────

model MaintenanceRecord {
  id                     String    @id @default(uuid())
  vehicleId              String
  expenseId              String?   @unique
  description            String
  cost                   Decimal   @db.Decimal(12, 2)
  date                   DateTime
  mileage                Int?
  serviceProvider        String?
  warrantyUntil          DateTime?
  nextMaintenanceMileage Int?
  notes                  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  vehicle Vehicle  @relation(fields: [vehicleId], references: [id])
  expense Expense? @relation(fields: [expenseId], references: [id])

  @@index([vehicleId])
  @@map("maintenance_records")
}

// ─────────────────────────────────────────────
// Toll Management domain
// ─────────────────────────────────────────────

model HgsTransit {
  id          String    @id @default(uuid())
  vehicleId   String
  shiftId     String?
  transitTime DateTime
  tollBooth   String
  amount      Decimal   @db.Decimal(10, 2)
  provider    String?
  referenceNo String?   @unique
  rawData     Json?
  syncedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  shift   Shift?  @relation(fields: [shiftId], references: [id])

  @@index([vehicleId])
  @@index([shiftId])
  @@index([transitTime])
  @@map("hgs_transits")
}

// ─────────────────────────────────────────────
// Timeline domain
// ─────────────────────────────────────────────

model TimelineEvent {
  id          String   @id @default(uuid())
  vehicleId   String
  shiftId     String?
  eventType   String
  description String
  eventTime   DateTime @default(now())
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  shift   Shift?  @relation(fields: [shiftId], references: [id])

  @@index([vehicleId])
  @@index([shiftId])
  @@index([eventType])
  @@index([createdAt])
  @@map("timeline_events")
}

// ─────────────────────────────────────────────
// Import domain
// ─────────────────────────────────────────────

model ImportJob {
  id             String       @id @default(uuid())
  source         ImportSource
  status         ImportStatus @default(PENDING)
  rawContent     String       @db.Text
  parsedContent  Json?
  driverReportId String?      @unique
  error          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  driverReport DriverReport? @relation(fields: [driverReportId], references: [id])

  @@index([source])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("import_jobs")
}

// ─────────────────────────────────────────────
// Document Management domain
// ─────────────────────────────────────────────

model Document {
  id         String       @id @default(uuid())
  ownerType  OwnerType
  ownerId    String
  title      String
  type       DocumentType
  issueDate  DateTime?
  expiryDate DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  deletedAt  DateTime?

  revisions DocumentRevision[]

  @@index([ownerType, ownerId])
  @@index([type])
  @@index([expiryDate])
  @@index([deletedAt])
  @@map("documents")
}

model DocumentRevision {
  id         String   @id @default(uuid())
  documentId String
  version    Int
  fileName   String
  fileUrl    String
  mimeType   String
  size       Int
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id])

  @@unique([documentId, version])
  @@index([documentId])
  @@map("document_revisions")
}

// ─────────────────────────────────────────────
// Notification domain
// ─────────────────────────────────────────────

model Notification {
  id        String    @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean   @default(false)
  readAt    DateTime?
  type      String
  metadata  Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}
